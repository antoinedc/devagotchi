#!/bin/bash
# Devagotchi Setup
# Installs dependencies, builds, and verifies the skill

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

echo "🐾 Setting up Devagotchi..."
echo ""

# Check Node.js
if ! command -v node &> /dev/null; then
    echo "❌ Node.js is required. Install it from https://nodejs.org/"
    exit 1
fi

NODE_VERSION=$(node -v | sed 's/v//' | cut -d. -f1)
if [ "$NODE_VERSION" -lt 18 ]; then
    echo "❌ Node.js 18+ required (found v$NODE_VERSION)"
    exit 1
fi

# Install deps
echo "📦 Installing dependencies..."
npm install --silent 2>/dev/null

# Build
echo "🔨 Building..."
npm run build --silent 2>/dev/null

# Verify build
if [ ! -f "dist/cli.js" ]; then
    echo "❌ Build failed. Try running: npm install && npm run build"
    exit 1
fi

# Install statusline hook into Claude Code settings
echo "📊 Setting up status bar..."
SETTINGS_FILE="$HOME/.claude/settings.json"
HOOK_CMD="node $SCRIPT_DIR/hooks/devagotchi-statusline.js"

if [ -f "$SETTINGS_FILE" ]; then
    # Check if statusLine is already configured
    if node -e "
        const s = JSON.parse(require('fs').readFileSync('$SETTINGS_FILE', 'utf8'));
        if (s.statusLine && s.statusLine.command && s.statusLine.command.includes('devagotchi')) {
            process.exit(0); // already installed
        } else if (s.statusLine) {
            process.exit(2); // another statusline exists
        } else {
            process.exit(1); // no statusline, install
        }
    " 2>/dev/null; then
        echo "   Status bar already configured."
    elif [ $? -eq 2 ]; then
        echo "   ⚠️  Another status bar is configured. Skipping (add manually if you want)."
        echo "   Add to ~/.claude/settings.json: \"statusLine\": {\"type\": \"command\", \"command\": \"$HOOK_CMD\"}"
    else
        # Install statusline
        node -e "
            const fs = require('fs');
            const s = JSON.parse(fs.readFileSync('$SETTINGS_FILE', 'utf8'));
            s.statusLine = { type: 'command', command: '$HOOK_CMD' };
            fs.writeFileSync('$SETTINGS_FILE', JSON.stringify(s, null, 2));
        " 2>/dev/null && echo "   ✅ Status bar installed!" || echo "   ⚠️  Could not update settings.json"
    fi
else
    # Create settings with statusline
    mkdir -p "$HOME/.claude"
    echo "{\"statusLine\":{\"type\":\"command\",\"command\":\"$HOOK_CMD\"}}" > "$SETTINGS_FILE"
    echo "   ✅ Status bar installed!"
fi

# Install auto-feed hook (Stop event)
echo "🍖 Setting up auto-feed..."
AUTOFEED_CMD="node $SCRIPT_DIR/hooks/devagotchi-autofeed.js"

if [ -f "$SETTINGS_FILE" ]; then
    node -e "
        const fs = require('fs');
        const s = JSON.parse(fs.readFileSync('$SETTINGS_FILE', 'utf8'));
        if (!s.hooks) s.hooks = {};
        if (!s.hooks.Stop) s.hooks.Stop = [];
        const hasIt = s.hooks.Stop.some(e => e.hooks && e.hooks.some(h => h.command && h.command.includes('devagotchi-autofeed')));
        if (!hasIt) {
            s.hooks.Stop.push({ hooks: [{ type: 'command', command: '$AUTOFEED_CMD', timeout: 15 }] });
            fs.writeFileSync('$SETTINGS_FILE', JSON.stringify(s, null, 2));
            console.log('   \x1b[32m✓\x1b[0m Auto-feed hook installed (runs on session end)');
        } else {
            console.log('   Auto-feed already configured.');
        }
    " 2>/dev/null || echo "   \u26a0\ufe0f  Could not install auto-feed hook"
fi

echo ""
echo "✅ Devagotchi installed!"
echo ""
echo "   Run /devagotchi in Claude Code to hatch your pet."
echo "   Your pet feeds automatically when sessions end 🍖"
echo "   Status bar shows your pet's mood 🐾"
echo ""
# Show a quick preview
node dist/cli.js 2>/dev/null || true
